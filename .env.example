# Domain database. SQLite works without Docker; Compose overrides this with PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///./data/oplab.db

# LangGraph checkpoints are intentionally separate from domain state.
CHECKPOINT_DATABASE_URL=./data/checkpoints.sqlite

# OpenAI-compatible model endpoint. Omit the key to run the deterministic demo path.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini

# Retrieval and runtime limits.
OPENALEX_MAILTO=
RETRIEVAL_LIMIT=8
MAX_SOURCE_BYTES=5000000
API_CORS_ORIGINS=http://localhost:3000
OPLAB_ARTIFACT_ROOT=./artifacts
OPLAB_UPLOAD_ROOT=./uploads

# Browser-side API base URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
